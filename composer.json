{
    "name": "kocenik/laravel-language-commands",
    "description": "Useful Laravel commands for working with languages",
    "keywords": ["laravel", "commands", "language"],
    "minimum-stability": "stable",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "kocenik",
            "email": "kocenik03@gmail.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/console": "^12.0",
        "illuminate/support": "^12.0"
    },
    "autoload": {
        "psr-4": {
            "Kocenik\\LaravelLanguageCommands\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Kocenik\\LaravelLanguageCommands\\ServiceProvider"
            ]
        }
    }
}
